{
	"name": "galatanovidiu/wp-ai-agent",
	"description": "A CLI-based AI agent using MCP and Anthropic Claude",
	"type": "project",
	"license": "MIT",
	"require": {
		"php": ">=8.4",
		"galatanovidiu/php-mcp-client": "dev-trunk",
		"guzzlehttp/guzzle": "^7.10",
		"psr/log": "^1.0|^2.0|^3.0",
		"symfony/yaml": "^8.0"
	},
	"require-dev": {
		"php-stubs/wp-cli-stubs": "^2.12",
		"phpstan/phpstan": "^1.0",
		"phpunit/phpunit": "^10.0",
		"squizlabs/php_codesniffer": "^3.0",
		"wordpress/ai-provider-for-anthropic": "dev-trunk",
		"wordpress/ai-provider-for-google": "dev-trunk",
		"wordpress/ai-provider-for-openai": "dev-trunk",
		"wordpress/php-ai-client": "dev-trunk"
	},
	"autoload": {
		"psr-4": {
			"WpAiAgent\\": "src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"WpAiAgent\\Tests\\": "tests/"
		}
	},
	"repositories": [
		{
			"type": "vcs",
			"url": "https://github.com/galatanovidiu/php-mcp-client"
		},
		{
			"type": "vcs",
			"url": "https://github.com/WordPress/php-ai-client"
		},
		{
			"type": "vcs",
			"url": "https://github.com/WordPress/php-mcp-schema"
		},
		{
			"type": "vcs",
			"url": "https://github.com/WordPress/ai-provider-for-anthropic"
		},
		{
			"type": "vcs",
			"url": "https://github.com/WordPress/ai-provider-for-google"
		},
		{
			"type": "vcs",
			"url": "https://github.com/WordPress/ai-provider-for-openai"
		}
	],
	"minimum-stability": "dev",
	"prefer-stable": true,
	"config": {
		"platform": {
			"php": "8.4"
		},
		"sort-packages": true,
		"optimize-autoloader": true
	},
	"scripts": {
		"test": "phpunit",
		"phpcs": "phpcs",
		"phpstan": "phpstan analyse"
	}
}
