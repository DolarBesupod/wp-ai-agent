{
	"name": "galatanovidiu/php-cli-agent",
	"description": "A CLI-based AI agent using MCP and Anthropic Claude",
	"type": "project",
	"license": "MIT",
	"require": {
		"php": ">=8.1",
		"ovidiu/mcp-client": "dev-trunk",
		"wordpress/php-ai-client": "dev-trunk",
		"symfony/yaml": "^5.0|^6.0|^7.0",
		"psr/log": "^1.0|^2.0|^3.0"
	},
	"require-dev": {
		"phpunit/phpunit": "^10.0",
		"phpstan/phpstan": "^1.0",
		"squizlabs/php_codesniffer": "^3.0"
	},
	"autoload": {
		"psr-4": {
			"PhpCliAgent\\": "src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"PhpCliAgent\\Tests\\": "tests/"
		}
	},
	"repositories": [
		{
			"type": "vcs",
			"url": "https://github.com/galatanovidiu/php-mcp-client"
		},
		{
			"type": "vcs",
			"url": "https://github.com/WordPress/php-ai-client"
		},
		{
			"type": "vcs",
			"url": "https://github.com/WordPress/php-mcp-schema"
		}
	],
	"minimum-stability": "dev",
	"prefer-stable": true,
	"config": {
		"sort-packages": true,
		"optimize-autoloader": true
	},
	"scripts": {
		"test": "phpunit",
		"phpcs": "phpcs",
		"phpstan": "phpstan analyse"
	}
}
